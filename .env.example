# =============================================================================
# devTinder — environment variables (multi-environment via dotenvx)
#
# Layered files (later overrides earlier):
#   .env              — shared defaults (gitignored; copy from this file)
#   .env.development  — dev overrides (committed, non-secret)
#   .env.test         — test defaults (committed)
#   .env.production   — prod overrides on server (gitignored; see .env.production.example)
#   .env.local        — machine-specific secrets (gitignored)
#
# Scripts: npm run dev | test | start:prod
# PM2:     pm2 start ecosystem.config.cjs --env production
# =============================================================================

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Logging ─────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/devTinder
DB_NAME=devTinder
# Optional — only if your cluster requires auth
DB_USER=
DB_PASS=

# ─── HTTP / security ─────────────────────────────────────────────────────────
# Comma-separated origins for CORS (omit or use * for open dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Max requests per IP per 15-minute window
RATE_LIMIT_MAX=100

# ─── JWT (jose) — required in production ─────────────────────────────────────
# Secrets must be at least 32 characters. Use: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long

# Legacy alias — used only if JWT_ACCESS_SECRET is unset
# JWT_SECRET=

JWT_ISSUER=devTinder
JWT_AUDIENCE=devTinder:api
# HS256 (default) | RS256 | ES256
JWT_ALGORITHM=HS256

# Asymmetric (RS256/ES256) — PEM with literal newlines or \\n escapes
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# JWT_JWKS_URI=https://your-idp/.well-known/jwks.json
# JWT_KEY_ID=key-2026-01

# Redis / Valkey (refresh-token revocation denylist)
REDIS_URL=redis://127.0.0.1:6379

# Session denylist (refresh tokens get jti; revoked on rotation)
# JWT_SESSION_TRACKING=true
# JWT_REVOKE_KEY_PREFIX=devtinder:jwt:revoked:

# Verification clock skew (jose duration string)
# JWT_CLOCK_TOLERANCE=5s

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

JWT_ACCESS_COOKIE=accessToken
JWT_REFRESH_COOKIE=refreshToken

# Cookie policy — for cross-site SPAs use JWT_COOKIE_SAME_SITE=none and JWT_COOKIE_SECURE=true
# JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_SECURE=
# JWT_COOKIE_PATH=/
# JWT_COOKIE_DOMAIN=
# JWT_COOKIE_HTTP_ONLY=true


# ─── AWS (shared defaults + per-service overrides) ───────────────────────────
# Optional global defaults — service-specific vars fall back to these.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SES (Simple Email Service)
# AWS_SES_ENABLED=true
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=ses-access-key-id-placeholder
AWS_SES_SECRET_ACCESS_KEY=ses-secret-access-key-placeholder
